{
  "name": "bebedura",
  "version": "1.0.0",
  "private": true,
  "description": "App mobile-first Bebedura para distribuidora de bebidas com catalogo, estoque, carrinho, pedidos e painel do proprietario.",
  "scripts": {
    "serve": "npx http-server www -p 4173 -c-1",
    "cap:init": "npx cap init \"bebedura\" br.com.bebedura.app --web-dir www",
    "cap:add:android": "npx cap add android",
    "cap:add:ios": "npx cap add ios",
    "cap:sync": "npx cap sync",
    "cap:open:android": "npx cap open android",
    "cap:open:ios": "npx cap open ios"
  },
  "devDependencies": {
    "@capacitor/android": "^8.0.0",
    "@capacitor/cli": "^8.0.0",
    "@capacitor/core": "^8.0.0",
    "@capacitor/ios": "^8.0.0",
    "http-server": "^14.1.1"
  }
}
